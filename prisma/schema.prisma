generator client {
  previewFeatures = ["driverAdapters"]
  provider = "prisma-client-js"
  output   = "./generated/client2"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                               String                             @id @default(cuid())
  fullName                         String
  email                            String                             @unique
  passwordHash                     String
  role                             String                             @default("PARENT")
  status                           String                             @default("ACTIVE")
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  inputAssessmentPeriods           InputAssessmentPeriod[]            @relation("PeriodAssignee")
  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]
  notifications                    Notification[]
  parent                           Parent?
  taskAttachments                  TaskAttachment[]                   @relation("TaskAttachments")
  taskComments                     TaskComment[]                      @relation("TaskComments")
  teacher                          Teacher?
  weeklyReports                    WeeklyReport[]
  receivedTasks                    WorkTask[]                         @relation("TaskAssignee")
  assignedTasks                    WorkTask[]                         @relation("TaskAssigner")
}

model Parent {
  id          String              @id @default(cuid())
  userId      String              @unique
  parentCode  String              @unique
  parentName  String
  email       String?
  phone       String?
  status      String              @default("ACTIVE")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  students    ParentStudentLink[]
  surveyForms SurveyForm[]
}

model Teacher {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  teacherCode        String                   @unique
  teacherName        String
  email              String?
  phone              String?
  homeroomClass      String?
  campusId           String
  status             String                   @default("ACTIVE")
  dateOfBirth        DateTime?
  departmentId       String?
  mainSubjectId      String?
  mainSubjectRel     Subject?                 @relation("teacherMainSubject", fields: [mainSubjectId], references: [id])
  departmentRel      Department?              @relation(fields: [departmentId], references: [id])
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campus             Campus                   @relation(fields: [campusId], references: [id])
  classes            TeacherClassAssignment[]
  TeachingAssignment TeachingAssignment[]
}

model Campus {
  id                     String                  @id @default(cuid())
  campusCode             String                  @unique
  campusName             String
  address                String?
  status                 String                  @default("ACTIVE")
  classes                Class[]
  inputAssessmentPeriods InputAssessmentPeriod[]
  students               Student[]
  summaries              SummaryByCampus[]
  surveyForms            SurveyForm[]
  teachers               Teacher[]
}

model AcademicYear {
  id                     String                  @id @default(cuid())
  name                   String
  startDate              DateTime
  endDate                DateTime
  status                 String                  @default("ACTIVE")
  assessmentConfigs      AssessmentConfig[]
  classes                Class[]
  educationSystems       EducationSystem[]
  inputAssessmentPeriods InputAssessmentPeriod[]
  students               Student[]
  subjectQuotas          SubjectQuota[]
  surveyForms            SurveyForm[]
  surveyPeriods          SurveyPeriod[]
  teachingAssignments    TeachingAssignment[]
  weeklyReports          WeeklyReport[]
  workTasks              WorkTask[]
}

model Class {
  id                  String                   @id @default(cuid())
  classCode           String                   @unique
  className           String
  level               String                   @default("Tieu hoc")
  grade               String                   @default("")
  campusId            String
  academicYearId      String
  homeroomTeacherId   String?
  status              String                   @default("ACTIVE")
  educationSystem     String?                  @default("")
  campus              Campus                   @relation(fields: [campusId], references: [id])
  academicYear        AcademicYear             @relation(fields: [academicYearId], references: [id])
  students            Student[]
  summaries           SummaryByClass[]
  surveyForms         SurveyForm[]
  teachers            TeacherClassAssignment[]
  teachingAssignments TeachingAssignment[]
}

model TeacherClassAssignment {
  id          String  @id @default(cuid())
  teacherId   String
  classId     String
  roleInClass String?
  status      String  @default("ACTIVE")
  class       Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
}

model Student {
  id             String              @id @default(cuid())
  studentCode         String
  studentName    String
  classId        String
  campusId       String
  academicYearId String
  status         String              @default("ACTIVE")
  dateOfBirth    DateTime?
  gender         String?
  parents        ParentStudentLink[]
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id])
  campus         Campus              @relation(fields: [campusId], references: [id])
  class          Class               @relation(fields: [classId], references: [id])
  surveyForms    SurveyForm[]
}

model ParentStudentLink {
  id           String  @id @default(cuid())
  parentId     String
  studentId    String
  relationship String?
  status       String  @default("ACTIVE")
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

model SurveyPeriod {
  id              String            @id @default(cuid())
  code            String            @unique
  name            String
  academicYearId  String
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean           @default(false)
  status          String            @default("ACTIVE")
  campusSummaries SummaryByCampus[]
  classSummaries  SummaryByClass[]
  systemSummaries SummarySystem?
  surveyForms     SurveyForm[]
  academicYear    AcademicYear      @relation(fields: [academicYearId], references: [id])
  questions       SurveyQuestion[]
}

model SurveySection {
  id        String           @id @default(cuid())
  code      String           @unique
  name      String
  sortOrder Int              @default(0)
  status    String           @default("ACTIVE")
  questions SurveyQuestion[]
}

model SurveyQuestion {
  id             String           @id @default(cuid())
  code           String           @unique
  questionText   String
  sectionId      String?
  surveyPeriodId String?
  questionType   String
  ratingScaleMin Int?             @default(1)
  ratingScaleMax Int?             @default(5)
  options        String?
  weight         Float            @default(1.0)
  isRequired     Boolean          @default(true)
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  surveyPeriod   SurveyPeriod?    @relation(fields: [surveyPeriodId], references: [id])
  section        SurveySection?   @relation(fields: [sectionId], references: [id])
  responses      SurveyResponse[]
}

model SurveyForm {
  id                  String           @id @default(cuid())
  surveyPeriodId      String
  parentId            String
  studentId           String
  classId             String
  campusId            String
  academicYearId      String
  submissionDateTime  DateTime         @default(now())
  submittedByEmail    String?
  overallAverageScore Float?
  npsScoreRaw         Int?
  npsCategory         String?
  status              String           @default("DRAFT")
  surveyPeriod        SurveyPeriod     @relation(fields: [surveyPeriodId], references: [id])
  parent              Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student             Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class               Class            @relation(fields: [classId], references: [id])
  campus              Campus           @relation(fields: [campusId], references: [id])
  academicYear        AcademicYear     @relation(fields: [academicYearId], references: [id])
  responses           SurveyResponse[]

  @@unique([parentId, studentId, surveyPeriodId])
}

model SurveyResponse {
  id                      String         @id @default(cuid())
  formId                  String
  questionId              String
  numericScore            Int?
  textAnswer              String?
  choiceAnswer            String?
  calculatedWeightedScore Float?
  createdAt               DateTime       @default(now())
  question                SurveyQuestion @relation(fields: [questionId], references: [id])
  form                    SurveyForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model SummaryByClass {
  id                       String       @id @default(cuid())
  surveyPeriodId           String
  classId                  String
  totalStudents            Int          @default(0)
  surveyedStudents         Int          @default(0)
  notSurveyedStudents      Int          @default(0)
  completionRate           Float        @default(0)
  averageSatisfactionScore Float?       @default(0)
  promoterCount            Int          @default(0)
  passiveCount             Int          @default(0)
  detractorCount           Int          @default(0)
  npsValue                 Float?       @default(0)
  updatedAt                DateTime     @updatedAt
  class                    Class        @relation(fields: [classId], references: [id])
  surveyPeriod             SurveyPeriod @relation(fields: [surveyPeriodId], references: [id])

  @@unique([surveyPeriodId, classId])
}

model SummaryByCampus {
  id                       String       @id @default(cuid())
  surveyPeriodId           String
  campusId                 String
  totalStudents            Int          @default(0)
  surveyedStudents         Int          @default(0)
  notSurveyedStudents      Int          @default(0)
  completionRate           Float        @default(0)
  averageSatisfactionScore Float?       @default(0)
  promoterCount            Int          @default(0)
  passiveCount             Int          @default(0)
  detractorCount           Int          @default(0)
  npsValue                 Float?       @default(0)
  updatedAt                DateTime     @updatedAt
  campus                   Campus       @relation(fields: [campusId], references: [id])
  surveyPeriod             SurveyPeriod @relation(fields: [surveyPeriodId], references: [id])

  @@unique([surveyPeriodId, campusId])
}

model SummarySystem {
  id                       String       @id @default(cuid())
  surveyPeriodId           String       @unique
  totalStudents            Int          @default(0)
  surveyedStudents         Int          @default(0)
  notSurveyedStudents      Int          @default(0)
  completionRate           Float        @default(0)
  averageSatisfactionScore Float?       @default(0)
  promoterCount            Int          @default(0)
  passiveCount             Int          @default(0)
  detractorCount           Int          @default(0)
  npsValue                 Float?       @default(0)
  updatedAt                DateTime     @updatedAt
  surveyPeriod             SurveyPeriod @relation(fields: [surveyPeriodId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subject {
  id            String               @id @default(cuid())
  subjectCode   String               @unique
  subjectName   String
  studyPrograms String?              @default("")
  level         String?              @default("ALL")
  description   String?
  status        String               @default("ACTIVE")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  quotas        SubjectQuota[]
  mainTeachers  Teacher[]            @relation("teacherMainSubject")
  assignments   TeachingAssignment[]
}

model TeachingAssignment {
  id             String       @id @default(cuid())
  teacherId      String
  classId        String
  subjectId      String
  academicYearId String
  semester       Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  teacher        Teacher      @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, classId, subjectId, academicYearId, semester])
}

model SubjectQuota {
  id             String       @id @default(cuid())
  subjectId      String
  academicYearId String
  quota          Int          @default(0)
  quotaPrimary   Int          @default(0)
  quotaMiddle    Int          @default(0)
  quotaHigh      Int          @default(0)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, academicYearId])
}

model Role {
  code        String       @id
  name        String
  description String?
  isSystem    Boolean      @default(false)
  permissions Permission[]
}

model Permission {
  id        String  @id @default(cuid())
  roleCode  String
  module    String
  canRead   Boolean @default(false)
  canCreate Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)
  role      Role    @relation(fields: [roleCode], references: [code], onDelete: Cascade)

  @@unique([roleCode, module])
}

model WorkTask {
  id               String           @id @default(cuid())
  category         String
  title            String
  description      String?
  assignedToRole   String           @default("KT_DBCL")
  assignedToUserId String?
  assignedById     String
  startDate        DateTime
  endDate          DateTime
  progress         String           @default("PENDING")
  month            Int?
  academicYearId   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  staffNote        String?
  staffUpdatedAt   DateTime?
  attachments      TaskAttachment[]
  comments         TaskComment[]
  assignedToUser   User?            @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  assignedBy       User             @relation("TaskAssigner", fields: [assignedById], references: [id])
  academicYear     AcademicYear?    @relation(fields: [academicYearId], references: [id])
}

model StudentAchievement {
  id                String   @id @default(cuid())
  competitionCode   String   @unique
  competitionName   String
  level             String
  grade             String
  nature            String
  organizingLevel   String?
  field             String
  recognition       String?
  participationType String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation("TaskComments", fields: [userId], references: [id])
  task      WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  fileName    String
  fileData    String
  fileSize    Int      @default(0)
  contentType String   @default("")
  createdAt   DateTime @default(now())
  user        User     @relation("TaskAttachments", fields: [userId], references: [id])
  task        WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model InputAssessmentPeriod {
  id                               String                             @id @default(cuid())
  code                             String                             @unique
  name                             String
  academicYearId                   String
  campusId                         String?
  assignedUserId                   String?
  startDate                        DateTime?
  endDate                          DateTime?
  description                      String?
  status                           String                             @default("ACTIVE")
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  batches                          InputAssessmentBatch[]
  academicYear                     AcademicYear                       @relation(fields: [academicYearId], references: [id])
  campus                           Campus?                            @relation(fields: [campusId], references: [id])
  assignedUser                     User?                              @relation("PeriodAssignee", fields: [assignedUserId], references: [id])
  students                         InputAssessmentStudent[]
  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]
}

model InputAssessmentBatch {
  id                               String                             @id @default(cuid())
  periodId                         String
  batchNumber                      Int
  name                             String
  startDate                        DateTime
  endDate                          DateTime
  status                           String                             @default("ACTIVE")
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  period                           InputAssessmentPeriod              @relation(fields: [periodId], references: [id], onDelete: Cascade)
  students                         InputAssessmentStudent[]
  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]

  @@unique([periodId, batchNumber])
}

model WeeklyReport {
  id             String             @id @default(cuid())
  userId         String
  weekNumber     Int
  month          Int
  year           Int
  academicYearId String?
  status         String             @default("DRAFT")
  managerComment String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  academicYear   AcademicYear?      @relation(fields: [academicYearId], references: [id])
  user           User               @relation(fields: [userId], references: [id])
  items          WeeklyReportItem[]
}

model WeeklyReportItem {
  id               String       @id @default(cuid())
  reportId         String
  mainTask         String
  workContent      String
  progress         String       @default("NOT_STARTED")
  proposedSolution String?
  managerNote      String?
  createdAt        DateTime     @default(now())
  report           WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model InputAssessmentStudent {
  id                  String                   @id @default(cuid())
  studentCode         String
  fullName            String
  dateOfBirth         DateTime?
  className           String?
  academicRating      String?
  conductRating       String?
  admissionCriteria   String?
  surveySystem        String?
  targetType          String?
  psychologyScore     Float?
  writtenEnglishScore Float?
  oralEnglishScore    Float?
  mathScore           Float?
  literatureScore     Float?
  periodId            String
  batchId             String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  @@unique([studentCode, periodId])
  signatureName       String?
  surveyFormType      String?
  hocKy               String?
  kqHocTap            String?
  kqRenLuyen          String?
  kqgdTieuHoc         String?
  grade               String?
  hoSoCtQuocTe        String?
  admissionResult     String?
  directorNote        String?
  batch               InputAssessmentBatch?    @relation(fields: [batchId], references: [id])
  period              InputAssessmentPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  scores              StudentAssessmentScore[]
}

model AssessmentGrade {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}

model AssessmentSystem {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}

model AssessmentSubject {
  id                               String                             @id @default(cuid())
  code                             String                             @unique
  name                             String
  subjectType                      String?
  scoreColumns                     Int                                @default(1)
  commentColumns                   Int                                @default(1)
  sortOrder                        Int                                @default(0)
  status                           String                             @default("ACTIVE")
  createdAt                        DateTime                           @default(now())
  columnNames                      String?
  gradeMappings                    GradeSubjectMapping[]
  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]
  studentScores                    StudentAssessmentScore[]
}

model EducationSystem {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  academicYearId String
  status         String       @default("ACTIVE")
  createdAt      DateTime     @default(now())
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
}

model GradeSubjectMapping {
  id              String            @id @default(cuid())
  grade           String
  educationSystem String
  subjectId       String
  createdAt       DateTime          @default(now())
  subject         AssessmentSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([grade, educationSystem, subjectId])
}

model AssessmentConfig {
  id             String        @id @default(cuid())
  categoryType   String
  code           String
  name           String
  status         String        @default("ACTIVE")
  sortOrder      Int           @default(0)
  academicYearId String?
  createdAt      DateTime      @default(now())
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([categoryType, code, academicYearId])
}

model InputAssessmentTeacherAssignment {
  id                  String                @id @default(cuid())
  periodId            String
  batchId             String?
  userId              String
  subjectId           String
  grade               String
  educationSystem     String
  unlockRequestStatus String                @default("NONE")
  unlockReason        String?
  createdAt           DateTime              @default(now())
  subject             AssessmentSubject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch               InputAssessmentBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  period              InputAssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([periodId, batchId, userId, subjectId, grade, educationSystem])
}

model Department {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  teachers    Teacher[]
}

model StudentAssessmentScore {
  id          String                 @id @default(cuid())
  studentId   String
  subjectId   String
  scores      String?
  comments    String?
  updatedAt   DateTime               @updatedAt
  teacherId   String?
  teacherName String?
  subject     AssessmentSubject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student     InputAssessmentStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
}

