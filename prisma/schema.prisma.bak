€Â¬Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¢Ä‚â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¢Ă„â€Ă‚Â¢Ä‚Â¢Ă¢â€Â¬Ă‚ÂÄ‚â€Ă‚Â¬Ă„â€Ă¢â‚¬ÂÄ‚â€Ă‚ÂÄ‚â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¬Ă„â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă‚Â¢Ä‚Â¢Ă¢â‚¬ÂĂ‚Â¬Ä‚â€Ă‚ÂÄ‚â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă‚Â¢Ä‚Â¢Ă¢â‚¬ÂĂ‚Â¬Ä‚â€Ă‚ÂÄ‚â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¢Ă„â€Ă‚Â¢Ä‚Â¢Ă¢â€Â¬Ă‚ÂÄ‚â€Ă‚Â¬Ă„â€Ă¢â‚¬ÂÄ‚â€Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¢Ä‚â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¢Ă„â€Ă‚Â¢Ä‚Â¢Ă¢â‚¬ÂĂ‚Â¬Ä‚â€Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¬Ä‚â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚ÂÄ‚â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă‚Â¢Ä‚Â¢Ă¢â‚¬ÂĂ‚Â¬Ä‚â€Ă‚ÂÄ‚â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¢Ă„â€Ă‚Â¢Ä‚Â¢Ă¢â€Â¬Ă‚ÂÄ‚â€Ă‚Â¬Ă„â€Ă¢â‚¬ÂÄ‚â€Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă‚Â¢Ä‚Â¢Ă¢â‚¬ÂĂ‚Â¬Ä‚â€Ă‚ÂÄ‚â€Ă¢â‚¬ÂÄ‚Â¢Ă¢â€Â¬Ă‚ÂĂ„â€Ă¢â‚¬ÂÄ‚â€Ă‚Â¡ S")
  level         String?              @default("ALL")
  description   String?
  status        String               @default("ACTIVE")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  quotas        SubjectQuota[]
  assignments   TeachingAssignment[]
  mainTeachers  Teacher[]           @relation("teacherMainSubject")
}

model TeachingAssignment {
  id             String       @id @default(cuid())
  teacherId      String
  classId        String
  subjectId      String
  academicYearId String
  semester       Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  teacher        Teacher      @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, classId, subjectId, academicYearId, semester])
}

model SubjectQuota {
  id             String       @id @default(cuid())
  subjectId      String
  academicYearId String
  quota          Int          @default(0)
  quotaPrimary   Int          @default(0)
  quotaMiddle    Int          @default(0)
  quotaHigh      Int          @default(0)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, academicYearId])
}

model Role {
  code        String       @id
  name        String
  description String?
  isSystem    Boolean      @default(false)
  permissions Permission[]
}

model Permission {
  id        String  @id @default(cuid())
  roleCode  String
  module    String
  canRead   Boolean @default(false)
  canCreate Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)
  role      Role    @relation(fields: [roleCode], references: [code], onDelete: Cascade)

  @@unique([roleCode, module])
}

model WorkTask {
  id               String           @id @default(cuid())
  category         String
  title            String
  description      String?
  assignedToRole   String           @default("KT_DBCL")
  assignedToUserId String?
  assignedById     String
  startDate        DateTime
  endDate          DateTime
  progress         String           @default("PENDING")
  month            Int?
  academicYearId   String?
  staffNote        String?
  staffUpdatedAt   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  academicYear     AcademicYear?    @relation(fields: [academicYearId], references: [id])
  assignedBy       User             @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignedToUser   User?            @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  comments         TaskComment[]
  attachments      TaskAttachment[]
}

model StudentAchievement {
  id                String   @id @default(cuid())
  competitionCode   String   @unique
  competitionName   String
  level             String
  grade             String
  nature            String
  organizingLevel   String?
  field             String
  recognition       String?
  participationType String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  task      WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("TaskComments", fields: [userId], references: [id])
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  fileName    String
  fileData    String
  fileSize    Int      @default(0)
  contentType String   @default("")
  createdAt   DateTime @default(now())
  task        WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation("TaskAttachments", fields: [userId], references: [id])
}

model InputAssessmentPeriod {
  id             String                   @id @default(cuid())
  code           String                   @unique
  name           String
  academicYearId String
  campusId       String?
  assignedUserId String?
  assignedUser   User?                    @relation("PeriodAssignee", fields: [assignedUserId], references: [id])
  campus         Campus?                  @relation(fields: [campusId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  description    String?
  status         String                   @default("ACTIVE")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  academicYear   AcademicYear             @relation(fields: [academicYearId], references: [id])
  batches        InputAssessmentBatch[]
  students       InputAssessmentStudent[]

  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]
}

model InputAssessmentBatch {
  id          String                @id @default(cuid())
  periodId    String
  batchNumber Int
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String                @default("ACTIVE")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  period      InputAssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  students                         InputAssessmentStudent[]
  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]

  @@unique([periodId, batchNumber])
}

model WeeklyReport {
  id             String             @id @default(cuid())
  userId         String
  weekNumber     Int
  month          Int
  year           Int
  academicYearId String?
  status         String             @default("DRAFT")
  managerComment String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id])
  academicYear   AcademicYear?      @relation(fields: [academicYearId], references: [id])
  items          WeeklyReportItem[]
}

model WeeklyReportItem {
  id               String       @id @default(cuid())
  reportId         String
  mainTask         String
  workContent      String
  progress         String       @default("NOT_STARTED")
  proposedSolution String?
  managerNote      String?
  createdAt        DateTime     @default(now())
  report           WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model InputAssessmentStudent {
  id                  String                @id @default(cuid())
  studentCode         String                @unique
  fullName            String
  dateOfBirth         DateTime?
  className           String?
  grade               String?
  academicRating      String?
  conductRating       String?
  admissionCriteria   String?
  surveySystem        String?
  targetType          String?
  surveyFormType      String?
  signatureName       String?
  hocKy               String?
  kqgdTieuHoc         String?
  kqHocTap            String?
  kqRenLuyen          String?
  hoSoCtQuocTe        String?
  psychologyScore     Float?
  writtenEnglishScore Float?
  oralEnglishScore    Float?
  mathScore           Float?
  literatureScore     Float?
  periodId            String
  batchId             String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  period              InputAssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  batch               InputAssessmentBatch? @relation(fields: [batchId], references: [id])
  scores              StudentAssessmentScore[]
}

model AssessmentGrade {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}

model AssessmentSystem {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}

model AssessmentSubject {
  id            String                @id @default(cuid())
  code          String                @unique
  name          String
  subjectType   String?
  scoreColumns    Int                   @default(1)
  commentColumns  Int                   @default(1)
  columnNames     String?               // JSON string
  sortOrder     Int                   @default(0)
  status        String                @default("ACTIVE")
  createdAt     DateTime              @default(now())
  gradeMappings GradeSubjectMapping[]

  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]
  studentScores StudentAssessmentScore[]
}

model EducationSystem {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  academicYearId String
  status         String       @default("ACTIVE")
  createdAt      DateTime     @default(now())
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
}

model GradeSubjectMapping {
  id              String            @id @default(cuid())
  grade           String
  educationSystem String
  subjectId       String
  subject         AssessmentSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())

  @@unique([grade, educationSystem, subjectId])
}

model AssessmentConfig {
  id             String        @id @default(cuid())
  categoryType   String
  code           String
  name           String
  status         String        @default("ACTIVE")
  sortOrder      Int           @default(0)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([categoryType, code, academicYearId])
}

model InputAssessmentTeacherAssignment {
  id              String   @id @default(cuid())
  periodId        String
  batchId         String?
  userId          String
  subjectId       String
  grade           String
  educationSystem String
  unlockRequestStatus String @default("NONE")
  unlockReason        String?
  createdAt       DateTime @default(now())

  period  InputAssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  batch   InputAssessmentBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject AssessmentSubject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([periodId, batchId, userId, subjectId, grade, educationSystem])
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  teachers    Teacher[]
}


model StudentAssessmentScore {
  id          String                @id @default(cuid())
  studentId   String
  subjectId   String
  scores      String?               // JSON string array of floats
  comments    String?               // JSON string array of strings
  updatedAt   DateTime              @updatedAt

  student     InputAssessmentStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject     AssessmentSubject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
}
