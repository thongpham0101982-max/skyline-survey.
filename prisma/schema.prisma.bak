generator client {
  provider = "prisma-client-js"
  output   = "./generated/client2"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                               String                             @id @default(cuid())
  fullName                         String
  email                            String                             @unique
  passwordHash                     String
  role                             String                             @default("PARENT")
  status                           String                             @default("ACTIVE")
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  notifications                    Notification[]
  parent                           Parent?
  teacher                          Teacher?
  assignedTasks                    WorkTask[]                         @relation("TaskAssigner")
  receivedTasks                    WorkTask[]                         @relation("TaskAssignee")
  taskComments                     TaskComment[]                      @relation("TaskComments")
  taskAttachments                  TaskAttachment[]                   @relation("TaskAttachments")
  weeklyReports                    WeeklyReport[]
  inputAssessmentPeriods           InputAssessmentPeriod[]            @relation("PeriodAssignee")
  InputAssessmentTeacherAssignment InputAssessmentTeacherAssignment[]
}

model Parent {
  id          String              @id @default(cuid())
  userId      String              @unique
  parentCode  String              @unique
  parentName  String
  email       String?
  phone       String?
  status      String              @default("ACTIVE")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  students    ParentStudentLink[]
  surveyForms SurveyForm[]
}


model Teacher {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  teacherCode        String                   @unique
  teacherName        String
  email              String?
  phone              String?
  homeroomClass      String?
  campusId           String
  status             String                   @default("ACTIVE")
  dateOfBirth        DateTime?
  departmentId       String?
  mainSubjectId      String?
  campus             Campus                   @relation(fields: [campusId], references: [id])
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentRel      Department?              @relation(fields: [departmentId], references: [id])
  mainSubjectRel     Subject?                 @relation("teacherMainSubject", fields: [mainSubjectId], references: [id])
  classes            TeacherClassAssignment[]
  TeachingAssignment TeachingAssignment[]
}

model Campus {
  id                     String                  @id @default(cuid())
  campusCode             String                  @unique
  campusName             String
  address                String?
  status                 String                  @default("ACTIVE")
  classes                Class[]
  students               Student[]
  summaries              SummaryByCampus[]
  surveyForms            SurveyForm[]
  teachers               Teacher[]
  inputAssessmentPeriods InputAssessmentPeriod[]
}

model AcademicYear {
  id                     String                  @id @default(cuid())
  name                   String
  startDate              DateTime
  endDate                DateTime
  status                 String                  @default("ACTIVE")
  classes                Class[]
  students               Student[]
  subjectQuotas          SubjectQuota[]
  surveyForms            SurveyForm[]
  surveyPeriods          SurveyPeriod[]
  teachingAssignments    TeachingAssignment[]
  workTasks              WorkTask[]
  weeklyReports          WeeklyReport[]
  inputAssessmentPeriods InputAssessmentPeriod[]
  educationSystems       EducationSystem[]
  assessmentConfigs      AssessmentConfig[]
}

model Class {
  id                  String                   @id @default(cuid())
  classCode           String                   @unique
  className           String
  level               String                   @default("Tieu hoc")
  grade               String                   @default("")
  campusId            String
  academicYearId      String
  homeroomTeacherId   String?
  educationSystem     String?                  @default("")
  status              String                   @default("ACTIVE")
  academicYear        AcademicYear             @relation(fields: [academicYearId], references: [id])
  campus              Campus                   @relation(fields: [campusId], references: [id])
  students            Student[]
  summaries           SummaryByClass[]
  surveyForms         SurveyForm[]
  teachers            TeacherClassAssignment[]
  teachingAssignments TeachingAssignment[]
}

model TeacherClassAssignment {
  id          String  @id @default(cuid())
  teacherId   String
  classId     String
  roleInClass String?
  status      String  @default("ACTIVE")
  class       Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
}

model Student {
  id             String              @id @default(cuid())
  studentCode    String              @unique
  studentName    String
  classId        String
  campusId       String
  academicYearId String
  status         String              @default("ACTIVE")
  dateOfBirth    DateTime?
  gender         String?
  parents        ParentStudentLink[]
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id])
  campus         Campus              @relation(fields: [campusId], references: [id])
  class          Class               @relation(fields: [classId], references: [id])
  surveyForms    SurveyForm[]
}

model ParentStudentLink {
  id           String  @id @default(cuid())
  parentId     String
  studentId    String
  relationship String?
  status       String  @default("ACTIVE")
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

model SurveyPeriod {
  id              String            @id @default(cuid())
  code            String            @unique
  name            String
  academicYearId  String
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean           @default(false)
  status          String            @default("ACTIVE")
  campusSummaries SummaryByCampus[]
  classSummaries  SummaryByClass[]
  systemSummaries SummarySystem?
  surveyForms     SurveyForm[]
  academicYear    AcademicYear      @relation(fields: [academicYearId], references: [id])
  questions       SurveyQuestion[]
}

model SurveySection {
  id        String           @id @default(cuid())
  code      String           @unique
  name      String
  sortOrder Int              @default(0)
  status    String           @default("ACTIVE")
  questions SurveyQuestion[]
}

model SurveyQuestion {
  id             String           @id @default(cuid())
  code           String           @unique
  questionText   String
  sectionId      String?
  surveyPeriodId String?
  questionType   String
  ratingScaleMin Int?             @default(1)
  ratingScaleMax Int?             @default(5)
  options        String?
  weight         Float            @default(1.0)
  isRequired     Boolean          @default(true)
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  surveyPeriod   SurveyPeriod?    @relation(fields: [surveyPeriodId], references: [id])
  section        SurveySection?   @relation(fields: [sectionId], references: [id])
  responses      SurveyResponse[]
}

model SurveyForm {
  id                  String           @id @default(cuid())
  surveyPeriodId      String
  parentId            String
  studentId           String
  classId             String
  campusId            String
  academicYearId      String
  submissionDateTime  DateTime         @default(now())
  submittedByEmail    String?
  overallAverageScore Float?
  npsScoreRaw         Int?
  npsCategory         String?
  status              String           @default("DRAFT")
  academicYear        AcademicYear     @relation(fields: [academicYearId], references: [id])
  campus              Campus           @relation(fields: [campusId], references: [id])
  class               Class            @relation(fields: [classId], references: [id])
  student             Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent              Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  surveyPeriod        SurveyPeriod     @relation(fields: [surveyPeriodId], references: [id])
  responses           SurveyResponse[]

  @@unique([parentId, studentId, surveyPeriodId])
}

model SurveyResponse {
  id                      String         @id @default(cuid())
  formId                  String
  questionId              String
  numericScore            Int?
  textAnswer              String?
  choiceAnswer            String?
  calculatedWeightedScore Float?
  createdAt               DateTime       @default(now())
  question                SurveyQuestion @relation(fields: [questionId], references: [id])
  form                    SurveyForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model SummaryByClass {
  id                       String       @id @default(cuid())
  surveyPeriodId           String
  classId                  String
  totalStudents            Int          @default(0)
  surveyedStudents         Int          @default(0)
  notSurveyedStudents      Int          @default(0)
  completionRate           Float        @default(0)
  averageSatisfactionScore Float?       @default(0)
  promoterCount            Int          @default(0)
  passiveCount             Int          @default(0)
  detractorCount           Int          @default(0)
  npsValue                 Float?       @default(0)
  updatedAt                DateTime     @updatedAt
  class                    Class        @relation(fields: [classId], references: [id])
  surveyPeriod             SurveyPeriod @relation(fields: [surveyPeriodId], references: [id])

  @@unique([surveyPeriodId, classId])
}

model SummaryByCampus {
  id                       String       @id @default(cuid())
  surveyPeriodId           String
  campusId                 String
  totalStudents            Int          @default(0)
  surveyedStudents         Int          @default(0)
  notSurveyedStudents      Int          @default(0)
  completionRate           Float        @default(0)
  averageSatisfactionScore Float?       @default(0)
  promoterCount            Int          @default(0)
  passiveCount             Int          @default(0)
  detractorCount           Int          @default(0)
  npsValue                 Float?       @default(0)
  updatedAt                DateTime     @updatedAt
  campus                   Campus       @relation(fields: [campusId], references: [id])
  surveyPeriod             SurveyPeriod @relation(fields: [surveyPeriodId], references: [id])

  @@unique([surveyPeriodId, campusId])
}

model SummarySystem {
  id                       String       @id @default(cuid())
  surveyPeriodId           String       @unique
  totalStudents            Int          @default(0)
  surveyedStudents         Int          @default(0)
  notSurveyedStudents      Int          @default(0)
  completionRate           Float        @default(0)
  averageSatisfactionScore Float?       @default(0)
  promoterCount            Int          @default(0)
  passiveCount             Int          @default(0)
  detractorCount           Int          @default(0)
  npsValue                 Float?       @default(0)
  updatedAt                DateTime     @updatedAt
  surveyPeriod             SurveyPeriod @relation(fields: [surveyPeriodId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

